<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <TextView
        android:id="@+id/txtTitleNoteList"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clickable="true"
        android:padding="6dp"
        android:text="Title"
        android:background="@color/promptBackground"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:textAppearance="@style/TextAppearance.AppCompat.SearchResult.Title">
    </TextView>
    <TextView
        android:id="@+id/txtContentNoteList"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Summary"
        android:clickable="true"
        android:padding="6dp"
        android:textAppearance="@style/TextAppearance.AppCompat.Small"
        app:layout_constraintTop_toBottomOf="@id/txtTitleNoteList"
        app:layout_constraintStart_toStartOf="parent"
        />
    <TextView
        android:id="@+id/txtLastModifiedNoteList"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="DateModified"
        android:clickable="true"
        android:padding="6dp"
        android:textAppearance="@style/TextAppearance.AppCompat.Small"
        app:layout_constraintTop_toBottomOf="@id/txtContentNoteList"
        app:layout_constraintStart_toStartOf="parent">
    </TextView>
</androidx.constraintlayout.widget.ConstraintLayout>